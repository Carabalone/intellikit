/**
 * HSACO Kernel Harness — generated by kerncap
 *
 * Loads a .hsaco code object and launches the kernel via hipModuleLaunchKernel.
 * No kernel source is compiled or #included; the harness is source-agnostic.
 *
 * Kernel:  {{ kernel_name }}
 * Symbol:  {{ kernel_symbol }}
 * Grid:    ({{ grid.x // block.x }}, {{ grid.y // block.y }}, {{ grid.z // block.z }}) blocks
 * Block:   ({{ block.x }}, {{ block.y }}, {{ block.z }}) threads
 * LDS:     {{ lds_size }} bytes
 */

#include <hip/hip_runtime.h>
#include <cstdio>
#include <cstdlib>
#include <cstring>
#include <fstream>
#include <vector>

#define HIP_CHECK(expr)                                                  \
    do {                                                                 \
        hipError_t _err = (expr);                                        \
        if (_err != hipSuccess) {                                        \
            fprintf(stderr, "HIP error %d at %s:%d: %s\n",              \
                    _err, __FILE__, __LINE__, hipGetErrorString(_err));   \
            exit(1);                                                     \
        }                                                                \
    } while (0)

static std::vector<char> read_bin(const char* path) {
    std::ifstream f(path, std::ios::binary | std::ios::ate);
    if (!f) { fprintf(stderr, "Cannot open %s\n", path); exit(1); }
    auto size = f.tellg();
    f.seekg(0);
    std::vector<char> buf(size);
    f.read(buf.data(), size);
    return buf;
}

static void write_bin(const char* path, const void* data, size_t size) {
    std::ofstream f(path, std::ios::binary);
    f.write(static_cast<const char*>(data), size);
}

int main(int argc, char** argv) {
    const char* hsaco_path = argc > 1 ? argv[1] : "kernel.hsaco";

    // Load the .hsaco module
    hipModule_t module;
    hipFunction_t function;
    HIP_CHECK(hipModuleLoad(&module, hsaco_path));

    const char* sym = "{{ kernel_symbol }}";
    hipError_t _sym_err = hipModuleGetFunction(&function, module, sym);
    if (_sym_err == hipErrorNotFound) {
        sym = "{{ kernel_symbol_alt }}";
        _sym_err = hipModuleGetFunction(&function, module, sym);
    }
    if (_sym_err != hipSuccess) {
        fprintf(stderr, "HIP error %d at %s:%d: %s\n",
                _sym_err, __FILE__, __LINE__, hipGetErrorString(_sym_err));
        exit(1);
    }

    printf("Loaded %s, function '%s'\n", hsaco_path, sym);

    // Allocate and load arguments
{% for arg in args %}
{% if arg.is_pointer %}
{% if arg.is_null | default(false) %}
    // arg_{{ arg.index }}: {{ arg.type | default("void*") }} {{ arg.name | default("") }} (NULL)
    void* d_arg{{ arg.index }} = nullptr;
{% elif arg.file %}
    // arg_{{ arg.index }}: {{ arg.type | default("void*") }} {{ arg.name | default("") }} ({{ arg.buffer_size }} bytes)
    void* d_arg{{ arg.index }} = nullptr;
    HIP_CHECK(hipMalloc(&d_arg{{ arg.index }}, {{ arg.buffer_size }}));
    {
        auto buf = read_bin("capture/{{ arg.file }}");
        HIP_CHECK(hipMemcpy(d_arg{{ arg.index }}, buf.data(),
                             {{ arg.buffer_size }}, hipMemcpyHostToDevice));
    }
{% else %}
    // arg_{{ arg.index }}: {{ arg.type | default("void*") }} {{ arg.name | default("") }} ({{ arg.buffer_size }} bytes, zero-filled placeholder)
    void* d_arg{{ arg.index }} = nullptr;
    HIP_CHECK(hipMalloc(&d_arg{{ arg.index }}, {{ arg.buffer_size }}));
    HIP_CHECK(hipMemset(d_arg{{ arg.index }}, 0, {{ arg.buffer_size }}));
{% endif %}
{% else %}
    // arg_{{ arg.index }}: {{ arg.type | default("unknown") }} {{ arg.name | default("") }} (scalar, {{ arg.size }} bytes)
    char arg{{ arg.index }}[{{ arg.size }}];
    {
        auto buf = read_bin("capture/{{ arg.file }}");
        std::memcpy(arg{{ arg.index }}, buf.data(), {{ arg.size }});
    }
{% endif %}
{% endfor %}

{% for ib in indirect_buffers %}
    // indirect_{{ ib.id }}: captured via pointer chasing ({{ ib.buffer_size }} bytes)
    void* d_indirect{{ ib.id }} = nullptr;
    HIP_CHECK(hipMalloc(&d_indirect{{ ib.id }}, {{ ib.buffer_size }}));
    {
        auto buf = read_bin("capture/{{ ib.file }}");
        HIP_CHECK(hipMemcpy(d_indirect{{ ib.id }}, buf.data(),
                             {{ ib.buffer_size }}, hipMemcpyHostToDevice));
    }
{% endfor %}

{% if pointer_relocations %}
    // Patch embedded device pointers to match new allocation addresses
{% for rel in pointer_relocations %}
    {
        void* target_base = d_{{ rel.target_type }}{{ rel.target_index }};
        void* patched_ptr = static_cast<char*>(target_base) + {{ rel.target_offset }};
        void* source_base = d_{{ rel.source_type }}{{ rel.source_index }};
        HIP_CHECK(hipMemcpy(
            static_cast<char*>(source_base) + {{ rel.source_offset }},
            &patched_ptr, sizeof(void*), hipMemcpyHostToDevice));
    }
{% endfor %}
{% endif %}

    // Pack arguments for hipModuleLaunchKernel
    void* args[] = {
{% for arg in args %}
{% if arg.is_pointer %}
        &d_arg{{ arg.index }}{{ "," if not loop.last else "" }}
{% else %}
        &arg{{ arg.index }}{{ "," if not loop.last else "" }}
{% endif %}
{% endfor %}
    };

    // Timing
    hipEvent_t start, stop;
    HIP_CHECK(hipEventCreate(&start));
    HIP_CHECK(hipEventCreate(&stop));

    // Launch kernel
    unsigned int gridX = {{ grid.x // block.x }};
    unsigned int gridY = {{ grid.y // block.y }};
    unsigned int gridZ = {{ grid.z // block.z }};
    unsigned int blockX = {{ block.x }};
    unsigned int blockY = {{ block.y }};
    unsigned int blockZ = {{ block.z }};
    size_t lds = {{ lds_size }};

    HIP_CHECK(hipEventRecord(start));

    HIP_CHECK(hipModuleLaunchKernel(function,
        gridX, gridY, gridZ,
        blockX, blockY, blockZ,
        lds, nullptr, args, nullptr));

    HIP_CHECK(hipEventRecord(stop));
    HIP_CHECK(hipEventSynchronize(stop));

    float ms = 0;
    HIP_CHECK(hipEventElapsedTime(&ms, start, stop));
    printf("Kernel execution time: %.3f ms\n", ms);

    // Save output buffers
{% for arg in args %}
{% if arg.is_pointer and not arg.is_const and not (arg.is_null | default(false)) %}
    {
        std::vector<char> out({{ arg.buffer_size }});
        HIP_CHECK(hipMemcpy(out.data(), d_arg{{ arg.index }},
                             {{ arg.buffer_size }}, hipMemcpyDeviceToHost));
        write_bin("reference_output/output_{{ arg.index }}.bin",
                  out.data(), {{ arg.buffer_size }});
        printf("Saved output arg_{{ arg.index }}: {{ arg.buffer_size }} bytes\n");
    }
{% endif %}
{% endfor %}

    // Cleanup
{% for arg in args %}
{% if arg.is_pointer %}
    HIP_CHECK(hipFree(d_arg{{ arg.index }}));
{% endif %}
{% endfor %}
{% for ib in indirect_buffers %}
    HIP_CHECK(hipFree(d_indirect{{ ib.id }}));
{% endfor %}
    HIP_CHECK(hipEventDestroy(start));
    HIP_CHECK(hipEventDestroy(stop));
    HIP_CHECK(hipModuleUnload(module));

    printf("Reproducer completed successfully.\n");
    return 0;
}
