# Makefile — generated by kerncap
# Kernel: {{ kernel_name }}

HIPCC ?= hipcc
CXXFLAGS ?= -O2 -std=c++20
{% for inc in include_paths %}
CXXFLAGS += -I{{ inc }}
{% endfor %}
{% for define in compile_defines %}
CXXFLAGS += -D{{ define }}
{% endfor %}

LDFLAGS ?=
{% if link_libraries %}
LDFLAGS += -Wl,--allow-shlib-undefined
{% endif %}
{% for path in link_paths %}
LDFLAGS += -L{{ path }} -Wl,-rpath,{{ path }}
{% endfor %}
{% for lib in link_libraries %}
LDFLAGS += -l{{ lib }}
{% endfor %}

TARGET = reproducer

.PHONY: all clean run

all: $(TARGET) reference_output

$(TARGET): reproducer.hip
	$(HIPCC) $(CXXFLAGS) -o $@ $< $(LDFLAGS)

reference_output:
	mkdir -p reference_output

run: $(TARGET) reference_output
	./$(TARGET)

clean:
	rm -f $(TARGET)
	rm -rf reference_output/
