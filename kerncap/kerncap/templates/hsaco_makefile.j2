# Makefile — generated by kerncap (hsaco mode)
# Kernel: {{ kernel_name }}
# GPU:    {{ gpu_arch }}

HIPCC ?= hipcc
CXXFLAGS ?= -O2 -std=c++20
GPU_ARCH ?= {{ gpu_arch }}

.PHONY: all clean run{% if has_kernel_source %} recompile{% endif %}

all: harness reference_output

harness: harness.hip
	$(HIPCC) $(CXXFLAGS) -o $@ $<

{% if has_kernel_source %}
recompile: kernel.hip
	$(HIPCC) --genco -O3 --offload-arch=$(GPU_ARCH) -o kernel.hsaco $<

{% endif %}
reference_output:
	mkdir -p reference_output

run: harness reference_output
	./harness kernel.hsaco

clean:
	rm -f harness
	rm -rf reference_output/
