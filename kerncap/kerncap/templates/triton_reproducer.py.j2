#!/usr/bin/env python3
"""Kernel reproducer — generated by kerncap.

Kernel:  {{ kernel_name }}
Grid:    ({{ grid.x }}, {{ grid.y }}, {{ grid.z }})
{% if autotune_config -%}
Autotune config: {{ autotune_config.get('kwargs', {}) }}
{%- endif %}
"""

import os
import sys
import time

import numpy as np
import torch
import triton.language as tl

SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))

# Add kernel source directory to path
sys.path.insert(0, SCRIPT_DIR)

# Import the kernel
from {{ kernel_module }} import {{ kernel_function }}

{% if autotune_config %}
# Bypass the autotuner — call the inner JITFunction directly with
# the exact config that was captured, so outputs are reproducible.
_kernel = {{ kernel_function }}.fn if hasattr({{ kernel_function }}, 'fn') else {{ kernel_function }}
{% else %}
_kernel = {{ kernel_function }}
{% endif %}

# Torch dtype string → (numpy dtype for raw I/O, torch dtype)
TORCH_DTYPE_MAP = {
    "torch.float16": (np.float16, torch.float16),
    "torch.float32": (np.float32, torch.float32),
    "torch.float64": (np.float64, torch.float64),
    "torch.bfloat16": (np.uint16, torch.bfloat16),
    "torch.int8": (np.int8, torch.int8),
    "torch.int16": (np.int16, torch.int16),
    "torch.int32": (np.int32, torch.int32),
    "torch.int64": (np.int64, torch.int64),
    "torch.bool": (np.bool_, torch.bool),
    "torch.uint8": (np.uint8, torch.uint8),
}


def load_tensor(path, dtype_str, shape, strides=None, storage_offset=0):
    """Load a binary file as a torch tensor on GPU.

    When *strides* is provided the raw storage bytes are loaded and the
    original non-contiguous view is reconstructed via torch.as_strided,
    which correctly replays padded or otherwise non-contiguous layouts.
    """
    np_dtype, torch_dtype = TORCH_DTYPE_MAP.get(dtype_str, (np.float32, torch.float32))
    raw = np.fromfile(path, dtype=np.uint8)
    if dtype_str == "torch.bfloat16":
        data = raw.view(np.uint16)
        tensor = torch.from_numpy(data.copy()).view(torch.bfloat16)
    else:
        data = raw.view(np_dtype)
        tensor = torch.from_numpy(data.copy()).to(dtype=torch_dtype)
    tensor = tensor.to(device="cuda")
    if strides is not None and shape:
        tensor = torch.as_strided(tensor, shape, strides, storage_offset)
    elif shape:
        tensor = tensor.reshape(shape)
    return tensor


def main():
    os.makedirs(os.path.join(SCRIPT_DIR, "reference_output"), exist_ok=True)

    # Load arguments
{% for arg in args %}
{% if arg.is_pointer %}
    # {{ arg.name }}: {{ arg.torch_dtype }} {{ arg.shape }}
{% if arg.strides %}
    {{ arg.name }} = load_tensor(os.path.join(SCRIPT_DIR, "capture", "{{ arg.file }}"), "{{ arg.torch_dtype }}", {{ arg.shape }}, strides={{ arg.strides }}, storage_offset={{ arg.storage_offset if arg.storage_offset else 0 }})
{% else %}
    {{ arg.name }} = load_tensor(os.path.join(SCRIPT_DIR, "capture", "{{ arg.file }}"), "{{ arg.torch_dtype }}", {{ arg.shape }})
{% endif %}
{% elif arg.value is none %}
    {{ arg.name }} = None
{% elif arg.type == "bool" %}
    {{ arg.name }} = {{ arg.value | string | capitalize }}
{% elif arg.type == "triton_dtype" %}
    {{ arg.name }} = tl.{{ arg.value }}
{% elif arg.type == "float" %}
    {{ arg.name }} = {{ arg.value }}
{% elif arg.type == "int" %}
    {{ arg.name }} = {{ arg.value }}
{% else %}
    {{ arg.name }} = {{ arg.value | tojson }}
{% endif %}
{% endfor %}

    grid = ({{ grid.x }}, {{ grid.y }}, {{ grid.z }})

    # Warmup
    _kernel[grid](
{% for arg in args %}
{% if not arg.get('is_autotune_config', false) %}
        {{ arg.name }}={{ arg.name }},
{% endif %}
{% endfor %}
{% if autotune_config %}
{% for key, value in autotune_config.get('kwargs', {}).items() %}
        {{ key }}={{ value | tojson }},
{% endfor %}
{% if autotune_config.get('num_warps') is not none %}
        num_warps={{ autotune_config['num_warps'] }},
{% endif %}
{% if autotune_config.get('num_stages') is not none %}
        num_stages={{ autotune_config['num_stages'] }},
{% endif %}
{% endif %}
    )
    torch.cuda.synchronize()

    # Timed run
    start = time.perf_counter()
    _kernel[grid](
{% for arg in args %}
{% if not arg.get('is_autotune_config', false) %}
        {{ arg.name }}={{ arg.name }},
{% endif %}
{% endfor %}
{% if autotune_config %}
{% for key, value in autotune_config.get('kwargs', {}).items() %}
        {{ key }}={{ value }},
{% endfor %}
{% if autotune_config.get('num_warps') is not none %}
        num_warps={{ autotune_config['num_warps'] }},
{% endif %}
{% if autotune_config.get('num_stages') is not none %}
        num_stages={{ autotune_config['num_stages'] }},
{% endif %}
{% endif %}
    )
    torch.cuda.synchronize()
    elapsed_ms = (time.perf_counter() - start) * 1000
    print(f"Kernel execution time: {elapsed_ms:.3f} ms")

    # Save output tensors
{% for arg in args %}
{% if arg.is_pointer and not arg.is_const %}
    {{ arg.name }}_out = {{ arg.name }}.detach().cpu().contiguous()
    if {{ arg.name }}_out.dtype == torch.bfloat16:
        {{ arg.name }}_out.view(torch.uint16).numpy().tofile(os.path.join(SCRIPT_DIR, "reference_output", "output_{{ arg.index }}.bin"))
    else:
        {{ arg.name }}_out.numpy().tofile(os.path.join(SCRIPT_DIR, "reference_output", "output_{{ arg.index }}.bin"))
    print("Saved output {{ arg.name }}:", {{ arg.name }}.numel() * {{ arg.name }}.element_size(), "bytes")
{% endif %}
{% endfor %}

    print("Reproducer completed successfully.")


if __name__ == "__main__":
    main()
